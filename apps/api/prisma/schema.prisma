generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Workspace {
  id            String   @id
  name          String
  namespace     String
  description   String
  memberCount   Int      @default(0)
  defaultChatId String
  catalogJson   Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model CenterRecord {
  id          String   @id
  workspaceId String
  kind        String
  payload     Json
  updatedAt   DateTime @updatedAt

  @@index([workspaceId, kind])
}
